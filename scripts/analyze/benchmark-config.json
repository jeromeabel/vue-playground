{
  "capture": {
    "preset": "desktop",
    "chromeFlags": "--incognito",
    "cpuSlowdownMultiplier": 4,
    "onlyCategories": "performance",
    "iterations": 5,
    "aggregation": "median"
  },
  "display": {
    "lighthouse": {
      "primary": ["Score", "TBT", "LCP", "DOM Size"],
      "secondary": ["FCP", "SI", "TTI", "MT Work"],
      "hidden": ["Max FID", "CLS"]
    },
    "trace": {
      "primary": ["scripting_ms_per_s", "longest_task_ms", "long_tasks_count", "fps"],
      "secondary": ["rendering_ms_per_s", "painting_ms_per_s", "raf_count", "raf_total_ms"],
      "hidden": ["af_count", "af_mean_ms", "af_p95_ms", "af_max_ms"]
    }
  },
  "approaches": {
    "basic": { "label": "Basic Table" },
    "primevue": { "label": "PrimeVue DataTable" },
    "tanstack": { "label": "TanStack Table" }
  }
}

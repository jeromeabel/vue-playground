{
  "name": "vue-playground",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "fetch-data": "tsx scripts/fetch-species.ts",
    "lighthouse:basic": "mkdir -p scripts/analyze/inputs/lighthouse && pnpm dlx lighthouse@13 http://localhost:4173/benchmark/basic-table --preset=desktop --only-categories=performance --throttling.cpuSlowdownMultiplier=4 --output=json --output-path=scripts/analyze/inputs/lighthouse/basic.json --chrome-flags='--headless=new --disable-gpu --incognito'",
    "lighthouse:primevue": "mkdir -p scripts/analyze/inputs/lighthouse && pnpm dlx lighthouse@13 http://localhost:4173/benchmark/primevue-table --preset=desktop --only-categories=performance --throttling.cpuSlowdownMultiplier=4 --output=json --output-path=scripts/analyze/inputs/lighthouse/primevue.json --chrome-flags='--headless=new --disable-gpu --incognito'",
    "lighthouse:tanstack": "mkdir -p scripts/analyze/inputs/lighthouse && pnpm dlx lighthouse@13 http://localhost:4173/benchmark/tanstack-table --preset=desktop --only-categories=performance --throttling.cpuSlowdownMultiplier=4 --output=json --output-path=scripts/analyze/inputs/lighthouse/tanstack.json --chrome-flags='--headless=new --disable-gpu --incognito'",
    "lighthouse:all": "pnpm lighthouse:basic && pnpm lighthouse:primevue && pnpm lighthouse:tanstack",
    "setup:python": "uv venv --clear scripts/analyze/.venv && VIRTUAL_ENV= uv pip install --python scripts/analyze/.venv/bin/python -e 'scripts/analyze[dev]'",
    "analyze:lighthouse": "scripts/analyze/.venv/bin/bench analyze lighthouse scripts/analyze/inputs/lighthouse/basic.json --name basic && scripts/analyze/.venv/bin/bench analyze lighthouse scripts/analyze/inputs/lighthouse/primevue.json --name primevue && scripts/analyze/.venv/bin/bench analyze lighthouse scripts/analyze/inputs/lighthouse/tanstack.json --name tanstack",
    "analyze:trace": "scripts/analyze/.venv/bin/bench analyze trace 'scripts/analyze/inputs/traces/Trace-*-basic.json' --name basic && scripts/analyze/.venv/bin/bench analyze trace 'scripts/analyze/inputs/traces/Trace-*-primevue.json' --name primevue && scripts/analyze/.venv/bin/bench analyze trace 'scripts/analyze/inputs/traces/Trace-*-tanstack.json' --name tanstack",
    "compare:lighthouse": "scripts/analyze/.venv/bin/bench compare scripts/analyze/outputs/analyses/*.lighthouse.json --chart scripts/analyze/outputs/comparisons/lighthouse-comparison.png --json-out public/data/benchmark-results.json",
    "compare:trace": "scripts/analyze/.venv/bin/bench compare scripts/analyze/outputs/analyses/*.trace.json --chart scripts/analyze/outputs/comparisons/trace-comparison.png --json-out public/data/trace-results.json",
    "test:python": "scripts/analyze/.venv/bin/pytest scripts/analyze/bench/ -v",
    "test:python:fast": "scripts/analyze/.venv/bin/pytest scripts/analyze/bench/ -v -m 'not slow'"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.92.9",
    "@tanstack/vue-table": "^8.21.3",
    "@tanstack/vue-virtual": "^3.13.22",
    "@vueuse/core": "^14.2.1",
    "primevue": "^4.5.4",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/vue-query-devtools": "^6.1.5",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  }
}
